# ── API Security ────────────────────────────────────────────
# Set a secret key to protect your API. Frontend must send X-API-Key header.
# Leave empty for local development (auth disabled).
API_SECRET_KEY=change-me-to-a-random-string

# ── DeepSeek LLM API ──────────────────────────────────────
# Get your key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ── Feishu (Lark) API (optional — content publishing) ─────
# Get these from: https://open.feishu.cn/app
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: parent folder for created docs
FEISHU_FOLDER_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Redis (optional — async tasks) ────────────────────────
REDIS_URL=redis://localhost:6379

# ── Chroma (optional — RAG vector search) ──────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
